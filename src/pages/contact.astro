---
import { BaseLayout } from '@astgov/theme';
import { siteConfig } from '../config/site.config';
---

<BaseLayout config={siteConfig} title="联系我们">
  <div class="page-section"><div class="container">
    <div class="breadcrumb"><a href="/">首页</a> &gt; <span>联系我们</span></div>
    <div class="page-content">
      <h1 class="page-title">联系我们</h1>
      <table class="contact-table"><tbody>
        {siteConfig.footer.contacts?.map(c => (
          <tr><td class="contact-label">{c.label}：</td><td class="contact-value">{c.value}</td></tr>
        ))}
      </tbody></table>
    </div>
  </div></div>
</BaseLayout>

<style>
.page-title{font-size:20px;text-align:center;color:var(--color-primary);margin-bottom:20px}
.contact-table{width:100%;max-width:600px;margin:0 auto;border-collapse:collapse}
.contact-table td{padding:10px 8px;border-bottom:1px solid var(--color-divider);font-size:14px;line-height:1.8}
.contact-label{width:100px;font-weight:bold;color:var(--color-primary);white-space:nowrap;vertical-align:top}
.contact-value{color:var(--color-text)}
</style>