---
import { BlogLayout } from '@astgov/theme';
import { getCollection, render } from 'astro:content';
import { siteConfig } from '../../config/site.config';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => {
    const parts = post.id.split('/');
    // id format: "news/001" — pop the last part as slug, first part as category
    const slug = parts.pop()!;
    const category = post.data.category || parts[0] || slug;
    return {
      params: { category, slug },
      props: { post },
    };
  });
}
const { post } = Astro.props;
const parts = post.id.split('/');
const category = post.data.category || parts[0] || '';
const { Content, headings } = await render(post);
const data = post.data;
const dateCN = `${data.date.slice(0,4)}年${data.date.slice(5,7)}月${data.date.slice(8,10)}日`;
const al = siteConfig.ui?.article?.authorLabel || '作者：';
const tl = siteConfig.ui?.article?.tagLabel || '标签：';
const bl = siteConfig.ui?.article?.backLinkText || '← 返回列表';
---
<BlogLayout
  title={data.title}
  description={data.summary}
  siteName={siteConfig.siteName}
  siteSubtitle={siteConfig.siteSubtitle}
  topBar={siteConfig.topBar}
  navItems={siteConfig.nav}
  footer={siteConfig.footer}
  colors={siteConfig.colors}
  defaultFontSize={siteConfig.defaultFontSize}
  ui={{ dropdownArrow: siteConfig.ui?.dropdownArrow, copyright: siteConfig.ui?.copyright }}
>
  <h1 class="article-title">{data.title}</h1>
  <div class="article-meta">
    <span>{dateCN}</span>
    <span>{al}{data.author}</span>
    {data.tags.length > 0 && <span>{tl}{data.tags.join(' / ')}</span>}
  </div>
  {data.summary && <p class="article-summary">{data.summary}</p>}
  <div class="article-content prose prose-lg max-w-none"><Content /></div>
  <div class="article-footer"><a href={`/${category}`} class="back-link">{bl}</a></div>
</BlogLayout>

<style>
.article-title{font-size:24px;font-weight:bold;text-align:center;color:var(--color-primary);margin-bottom:18px;line-height:1.4}
.article-meta{text-align:center;font-size:13px;color:#999;padding-bottom:15px;margin-bottom:20px;border-bottom:1px solid var(--color-divider)}
.article-meta span{margin:0 12px}
.article-summary{font-size:14px;color:#555;background:#F8F8F8;padding:12px 18px;margin-bottom:25px;border-left:4px solid var(--color-secondary);line-height:1.8}

.article-footer{margin-top:35px;padding-top:18px;border-top:1px solid var(--color-divider)}
.back-link{color:var(--color-link,#00F);font-size:14px}
@media(max-width:767px){.article-title{font-size:20px}.article-meta span{display:block;margin:2px 0}}
</style>
